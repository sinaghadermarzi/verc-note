# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ----------------------------------------------------------------------------

# Postgres connection string.
# Local example: postgresql://postgres:postgres@localhost:5432/notepad?schema=public
# On Vercel, use a pooled connection string (Neon / Vercel Postgres / Supabase).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Optional direct (non-pooled) connection used only by `prisma migrate`.
# Required by some hosts (Neon, Supabase) when DATABASE_URL points at a pooler.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Secret used to encrypt session/JWT data. Generate with: `openssl rand -base64 32`
AUTH_SECRET="generate-a-strong-random-secret"

# Google OAuth credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {origin}/api/auth/callback/google
#   local:      http://localhost:3000/api/auth/callback/google
#   production: https://your-app.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Canonical app URL. Auth.js infers this on Vercel, but set it for local dev.
# NEXTAUTH_URL="http://localhost:3000"
